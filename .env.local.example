# Copy to .env.local and fill in. Required for sign-in + sync (Phase 1+).
# After provisioning, run: bun run db:push   (applies schema to Neon)

# Neon Postgres connection string (auto-injected by the Vercel integration
# once you add Neon in the Vercel dashboard; for local dev, copy from Neon).
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the deployed app (no trailing slash). Local dev: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth client (Google Cloud Console → APIs & Services → Credentials →
# Create OAuth client → Web application). Add redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-preview-and-prod-domains>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
